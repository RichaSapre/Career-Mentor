# Frontend API base URL.
# Keep this as /api/backend to use the Next.js proxy route at src/app/api/backend/[...path]/route.ts.
NEXT_PUBLIC_API_BASE_URL=/api/backend

# Upstream backend base URL used by the Next.js proxy route.
# Example resulting PATCH URL from frontend:
# /api/backend/auth/user -> http://localhost:4300/api/backend/auth/user
BACKEND_URL=http://localhost:4300/api/backend

# Optional: dedicated public preview endpoint used by /market page.
# If omitted, app defaults to backend-provided preview URL.
# PUBLIC_MARKET_PREVIEW_URL=http://34.69.168.143:3000/alpha/api/v1/market/analyze/preview
